<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_settings.xml
    Settings screen: Audio Manager (Music / Voice) + Snooze time picker
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/PolshiedWhite"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Page title                                                    -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:fontFamily="@font/manrope_extrabold"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- CARD 1 — Audio Manager                                       -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/settings_24dp_icon"
                        app:tint="@color/junglegreen" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audio Manager"
                        android:fontFamily="@font/manrope_semibold"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <!-- ── Audio Type Selector ───────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alert Sound Type"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="10dp" />

                <RadioGroup
                    android:id="@+id/rg_audio_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Music option -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/select_audio_type"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_lock_silent_mode_off"
                            android:layout_marginBottom="6dp"
                            app:tint="@color/junglegreen"/>

                        <RadioButton
                            android:id="@+id/rb_audio_music"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ringtone"
                            android:fontFamily="@font/manrope_regular"
                            android:textSize="13sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Voice option -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/select_audio_type"
                        android:padding="12dp"
                        android:layout_marginStart="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_btn_speak_now"
                            android:layout_marginBottom="6dp"
                            app:tint="@color/junglegreen"/>

                        <RadioButton
                            android:id="@+id/rb_audio_voice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Voice Message"
                            android:fontFamily="@font/manrope_regular"
                            android:textSize="13sp"
                            android:gravity="center" />
                    </LinearLayout>

                </RadioGroup>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <!-- ── Music Tracks List (shown when Music is selected) ─ -->
                <LinearLayout
                    android:id="@+id/ll_music_tracks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose a ringtone"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="10dp" />

                    <!-- Preview stop button (hidden until preview starts) -->
                    <ImageButton
                        android:id="@+id/ib_preview_stop"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_media_pause"
                        android:background="@android:color/transparent"
                        android:layout_gravity="end"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Stop preview" />

                    <!-- Populated in code -->
                    <RadioGroup
                        android:id="@+id/rg_music_tracks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- ── Voice Tracks List (shown when Voice is selected) ─ -->
                <LinearLayout
                    android:id="@+id/ll_voice_tracks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose a voice message"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="10dp" />

                    <!-- Populated in code -->
                    <RadioGroup
                        android:id="@+id/rg_voice_tracks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- CARD 2 — Snooze Time                                         -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/snooze_24dp_icon"
                        app:tint="@color/junglegreen" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Snooze Duration"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:fontFamily="@font/manrope_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How long to delay the reminder"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:fontFamily="@font/manrope_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <!-- Snooze radio options — populated in code -->
                <RadioGroup
                    android:id="@+id/rg_snooze"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Save button                                                   -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textSize="16sp"
            app:cornerRadius="14dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>