<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="140dp"
    android:layout_height="160dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_schedule_card_normal"
    android:padding="16dp">

    <View
        android:id="@+id/vIconBg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_tab_selected"
        android:backgroundTint="@color/MintBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivMedIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/pill_24dp_icon"
        app:layout_constraintBottom_toBottomOf="@+id/vIconBg"
        app:layout_constraintEnd_toEndOf="@+id/vIconBg"
        app:layout_constraintStart_toStartOf="@+id/vIconBg"
        app:layout_constraintTop_toTopOf="@+id/vIconBg"
        app:tint="@color/junglegreen" />

    <ImageView
        android:id="@+id/ivStatusIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/check_24dp_icon"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/junglegreen"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvNowBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_now_badge"
        android:fontFamily="sans-serif-black"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="NOW"
        android:textColor="@color/white"
        android:textSize="8sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvSchedTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="09:00 AM"
        android:textColor="@color/StateGray"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vIconBg" />

    <TextView
        android:id="@+id/tvSchedName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Lisinopril"
        android:textColor="@color/Ebony"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSchedTime" />

    <TextView
        android:id="@+id/tvSchedDose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="10mg"
        android:textColor="@color/StateGray"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSchedName" />

</androidx.constraintlayout.widget.ConstraintLayout>
